# Supabase (crear proyecto en https://supabase.com y copiar aquí)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Opcional — Solo desarrollo: evitar validación estricta de email en registro.
# 1) Desplegar función: npx supabase functions deploy signup-no-validate
# 2) En Supabase Dashboard > Edge Functions > signup-no-validate > Secrets: SIGNUP_SECRET=una-clave-secreta
# 3) Aquí pon la misma clave y activa el flag. En producción NO uses estas variables.
# VITE_SKIP_EMAIL_VALIDATION=true
# VITE_SIGNUP_SECRET=una-clave-secreta

# Para crear el primer admin: registrar un usuario desde la app (registro visitante)
# y luego en Supabase Dashboard > SQL: UPDATE profiles SET role = 'admin' WHERE id = 'uuid-del-usuario';
